{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonchanggi.github.io/quant-dashboard/contracts/quant-research-summary.v1.schema.json",
  "title": "Quant research public summary contract v1",
  "description": "Common static summary contract consumed by quant-dashboard. It intentionally checks a small set of durable semantics and leaves project-specific detail fields extensible.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "contract",
    "projectId",
    "projectName",
    "generatedAt",
    "dataAsOf",
    "timezone",
    "detailUrl",
    "detailDataUrl",
    "status",
    "coverage",
    "highlights",
    "primaryEntities",
    "limitations",
    "sources",
    "automation",
    "payload"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "contract": {
      "const": "quant-research-summary"
    },
    "projectId": {
      "type": "string",
      "minLength": 2
    },
    "projectName": {
      "type": "string",
      "minLength": 2
    },
    "generatedAt": {
      "type": "string",
      "minLength": 8
    },
    "dataAsOf": {
      "type": "string",
      "minLength": 4
    },
    "timezone": {
      "type": "string",
      "minLength": 2
    },
    "detailUrl": {
      "type": "string",
      "minLength": 1
    },
    "detailDataUrl": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "state",
        "label",
        "cadence",
        "expectedFreshnessDays"
      ],
      "properties": {
        "state": {
          "enum": [
            "ok",
            "degraded",
            "stale"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 2
        },
        "cadence": {
          "type": "string",
          "minLength": 2
        },
        "expectedFreshnessDays": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "degradedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "minProperties": 1
    },
    "highlights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "label",
          "value",
          "description"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "value": {}
        }
      }
    },
    "primaryEntities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "symbol",
          "name",
          "label",
          "sector",
          "sectorLabel",
          "themes",
          "metrics",
          "signals",
          "warnings"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "sector": {
            "type": "string",
            "minLength": 1
          },
          "sectorLabel": {
            "type": "string",
            "minLength": 1
          },
          "themes": {
            "type": "array"
          },
          "metrics": {
            "type": "object"
          },
          "signals": {
            "type": "array"
          },
          "warnings": {
            "type": "array"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1
    },
    "automation": {
      "type": "object",
      "minProperties": 1
    },
    "payload": {
      "type": "object",
      "minProperties": 1
    }
  },
  "x-contractRules": {
    "summaryContract": "quant-research-summary",
    "schemaVersion": 1,
    "allowedStatusStates": [
      "ok",
      "degraded",
      "stale"
    ],
    "requiredTopLevelKeys": [
      "schemaVersion",
      "contract",
      "projectId",
      "projectName",
      "generatedAt",
      "dataAsOf",
      "timezone",
      "detailUrl",
      "detailDataUrl",
      "status",
      "coverage",
      "highlights",
      "primaryEntities",
      "limitations",
      "sources",
      "automation",
      "payload"
    ],
    "requiredStatusKeys": [
      "state",
      "label",
      "cadence",
      "expectedFreshnessDays"
    ],
    "requiredHighlightKeys": [
      "label",
      "value",
      "description"
    ],
    "requiredEntityKeys": [
      "symbol",
      "name",
      "label",
      "sector",
      "sectorLabel",
      "themes",
      "metrics",
      "signals",
      "warnings"
    ],
    "arrayKeys": [
      "highlights",
      "primaryEntities",
      "limitations",
      "sources"
    ],
    "entityArrayKeys": [
      "themes",
      "signals",
      "warnings"
    ],
    "objectKeys": [
      "status",
      "coverage",
      "automation",
      "payload"
    ]
  }
}
